@startuml RepairMe

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam shadowing false
skinparam linetype ortho

skinparam packageStyle rectangle

skinparam class {
    BackgroundColor #FDFEFE
    BorderColor #888888
    FontColor #2c3e50
}


' ───────────────────────────
' MODELOS
' ───────────────────────────

package "model" #D6EAF8 {

    class Usuario <<data class>> {
        - id : String
        - name : String
        - email : String
        - phone : String
        - role : String = "user"
        - createdAt : Long
        - apellidos : String
        - direccion : String
        - codigoPostal : String
        - localidad : String
        - dni : String
    }

    class Equipo <<data class>> {
        - devicesId : String
        - deviceBrand : String
        - deviceModel : String
        - deviceSN : String
        - userId : String
    }

    class Averia <<data class>> {
        - id : String
        - userId : String
        - tecnicoId : String
        - equipoId : String
        - tituloAveria : String
        - equipoNombre : String
        - descripcion : String
        - estado : String = "Pendiente"
        - precioAproximado : Double
        - presupuestoDefinitivo : Double
        - presupuestoAceptado : Boolean?
        - createdAt : Long
        - fechaEntrega : Long
        - updates : List<AveriaUpdate>
        - lineasPresupuesto : List<LineaPresupuesto>
    }

    class AveriaUpdate <<data class>> {
        - mensaje : String
        - createdAt : Long
        - autor : String = "tecnico"
    }

    class LineaPresupuesto <<data class>> {
        - concepto : String
        - cantidad : Int
        - precioUnitario : Double
    }

    enum EstadoAveria {
        Pendiente
        Asignada
        PrecioEnviado
        Presupuestada
        EnReparacion
        ListaParaRecoger
        Declinada
    }

    Averia "1" *-- "0..*" AveriaUpdate
    Averia "1" *-- "0..*" LineaPresupuesto
    Averia --> EstadoAveria
}


' ───────────────────────────
' REPOSITORIOS
' ───────────────────────────

package "repository" #D5F5E3 {

    class OperationsTemplateRepository {
        # ref(path: String) : DatabaseReference
        # newId(node: String) : String
        # setValue(path: String, value: Any, ok: () -> Unit, error: (String) -> Unit)
        # delete(path: String, ok: () -> Unit, error: (String) -> Unit)
    }

    class AuthRepository {
        - autenticacion : FirebaseAuth
        --
        + validarCorreoPassword(correo: String, contraseña: String,\n  validacionOK: (Usuario) -> Unit, validacionError: (String) -> Unit)
        + crearUsuario(email: String, password: String, nombre: String,\n  apellidos: String, telefono: String, direccion: String,\n  cp: String, localidad: String, dni: String,\n  creadoOK: () -> Unit, creadoError: (String) -> Unit)
    }

    class DeviceRepository {
        - auth : FirebaseAuth
        - NODE : String = "devices"
        --
        + crearEquipo(equipo: Equipo, error: (String) -> Unit, exito: (String) -> Unit)
        + obtenerEquipos(error: (String) -> Unit, exito: (List<Equipo>) -> Unit)
        + eliminarEquipo(devicesId: String, error: (String) -> Unit, exito: () -> Unit)
    }

    class RepairRepository {
        - auth : FirebaseAuth
        - NODE : String = "repairs"
        --
        + abrirAveria(averia: Averia, exito: () -> Unit, fallo: (String) -> Unit)
        + obtenerAveriasTodas(fallo: (String) -> Unit, exito: (List<Averia>) -> Unit)
        + obtenerAveriaUser(fallo: (String) -> Unit, exito: (List<Averia>) -> Unit)
        + obtenerAveriaId(fallo: (String) -> Unit, exito: (Averia) -> Unit, averiaId: String)
        + obtenerAveriasTecnico(fallo: (String) -> Unit, exito: (List<Averia>) -> Unit)
        + editarAveria(averiaEditada: Averia, exito: () -> Unit, fallo: (String) -> Unit)
        + eliminarAveria(averiaId: String, exito: () -> Unit, fallo: (String) -> Unit)
    }

    class UserRepository {
        - auth : FirebaseAuth
        - NODE : String = "users"
        --
        + obtenerCualquierUsuarioPorId(id: String,\n  exito: (Usuario) -> Unit, fallo: (String) -> Unit)
    }

    class TecnicoRepository {
        - auth : FirebaseAuth
        - NODE : String = "users"
        --
        + obtenerTecnicos(fallo: (String) -> Unit, exito: (List<Usuario>) -> Unit)
        + editarTecnicoParcial(tecnicoId: String, updates: Map<String, Any>,\n  fallo: (String) -> Unit, exito: () -> Unit)
        + eliminarTecnico(tecnicoId: String, fallo: (String) -> Unit, exito: () -> Unit)
    }

    OperationsTemplateRepository <|-- AuthRepository
    OperationsTemplateRepository <|-- DeviceRepository
    OperationsTemplateRepository <|-- RepairRepository
    OperationsTemplateRepository <|-- UserRepository
    OperationsTemplateRepository <|-- TecnicoRepository
}


' ───────────────────────────
' NAVEGACIÓN
' ───────────────────────────

package "ui.navigation" #FDEBD0 {

    class Rutas <<sealed class>> {
        - ruta : String
        ==
        LOGIN
        REGISTRO
        USERSCREEN
        ADD_EQUIPO
        ADMINSCREEN
        REGISTRO_TECNICO
        TECNICOSCREEN
        TESTCRUD
        REPAIRSSCREEN
        DETALLE_AVERIA_TECNICO
        DETALLE_AVERIA_FINALIZADA
        PROFILE
    }

    class AppNavigation {
        --
        + navegarApp()
    }

    AppNavigation --> Rutas
}


' ───────────────────────────
' PANTALLAS
' ───────────────────────────

package "ui.screens" #FDEBD0 {

    class LoginScreen <<Composable>> {
        - email : String
        - contrasena : String
        --
        + onNavigateToRegistro : () -> Unit
        + onNavigateToUserScreen : () -> Unit
        + onNavigateToTecnicoScreen : () -> Unit
        + onNavigateToAdminScreen : () -> Unit
    }

    class RegisterScreen <<Composable>> {
        - email : String
        - nombre : String
        - pass : String
        - apellidos : String
        - dni : String
        - telefono : String
        - direccion : String
        - codigoPostal : String
        --
        + onNavigateBack : () -> Unit
        + onRegisterSucess : () -> Unit
    }

    class UserScreen <<Composable>> {
        - equiposExpandido : Boolean
        - reparacionesExpandido : Boolean
        - presupuestosExpandido : Boolean
        - listaEquipos : List<Equipo>
        - listaAverias : List<Averia>
        - listaPresupuestadas : List<Averia>
        - dialogoAveria : Averia?
        --
        + onAddEquipo : () -> Unit
        + onVolver : () -> Unit
        + onVerEquipos : (Equipo) -> Unit
        + onVerAverias : (Averia) -> Unit
        + onGoToTestCrud : () -> Unit
        + onIrPerfil : () -> Unit
        -- inner composable --
        + DialogoPresupuestos(averia, onRechazar, onAceptar)
    }

    class AddEquipoScreen <<Composable>> {
        - marca : String
        - modelo : String
        - numeroSerie : String
        - anadirAveria : Boolean
        - descripcionAveria : String
        --
        + onGuardar : (Equipo) -> Unit
        + onVolver : () -> Unit
    }

    class AdminScreen <<Composable>> {
        - currentScreen : String?
        --
        + onLogOut : () -> Unit
        + onVerAverias : () -> Unit
        + onVerTecnicos : () -> Unit
        + onIrPerfil : () -> Unit
    }

    class TecnicoScreen <<Composable>> {
        - currentScreen : String?
        --
        + onAddEquipo : () -> Unit
        + onAveriaClick : (String) -> Unit
        + onReparacionesFinalizadasClick : (String) -> Unit
        + onIrPerfil : () -> Unit
    }

    class RepairListScreen <<Composable>> {
        - listaAverias : List<Averia>
        - repo : RepairRepository
        --
        + orangePrimary : Color
        + onBack : () -> Unit
        + onAveriaClick : (String) -> Unit
    }

    class RepairedListScreen <<Composable>> {
        - listaReparadas : List<Averia>
        - repo : RepairRepository
        --
        + orangePrimary : Color
        + onBack : () -> Unit
        + onAveriaClick : (String) -> Unit
    }

    class DetalleAveriaTecnicoScreen <<Composable>> {
        - averia : Averia?
        - cargando : Boolean
        - lineas : List<LineaPresupuesto>
        --
        + averiaId : String
        + onVolver : () -> Unit
    }

    class DetalleReparacionesFinalizadas <<Composable>> {
        - averia : Averia?
        - cliente : Usuario?
        - tecnico : Usuario?
        - cargando : Boolean
        - error : String?
        --
        + averiaId : String
        + onVolver : () -> Unit
        -- methods --
        - cargarAveriaUserTecnico()
        - pasarFechaEntregaAString(timestamp: Long) : String
    }

    class ProfileScreen <<Composable>> {
        --
        + onVolver : () -> Unit
    }

    class RepairsScreen <<Composable>> {
        --
        + onVolver : () -> Unit
    }

    class RegisterTecnicoScreen <<Composable>> {
        --
        + onNavigateBack : () -> Unit
        + onRegisterSucess : () -> Unit
    }

}

@enduml
