@startuml RepairMe

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam shadowing false
skinparam linetype ortho

skinparam packageStyle rectangle

skinparam class {
    BackgroundColor #FDFEFE
    BorderColor #888888
    FontColor #2c3e50
}

package "model" #D6EAF8 {

    class Usuario <<data class>> {
        @Exclude - id : String
        - name : String
        - email : String
        - phone : String
        - role : String = "user"
        - createdAt : Long
        - apellidos : String
        - direccion : String
        - codigoPostal : String
        - localidad : String
        - dni : String
        - estado : String = ""
    }

    class Equipo <<data class>> {
        - devicesId : String
        - deviceBrand : String
        - deviceModel : String
        - deviceSN : String
        - userId : String
    }

    class Averia <<data class>> {
        - id : String
        - userId : String
        - tecnicoId : String
        - equipoId : String
        - tituloAveria : String
        - equipoNombre : String
        - descripcion : String
        - estado : String = "Pendiente"
        - prioridad : String = "Media"
        - precioAproximado : Double
        - presupuestoDefinitivo : Double
        - presupuestoAceptado : Boolean?
        - createdAt : Long
        - fechaListo : Long
        - fechaEntrega : Long
        - updates : List<AveriaUpdate>
        - lineasPresupuesto : List<LineaPresupuesto>
    }

    class AveriaUpdate <<data class>> {
        - mensaje : String
        - createdAt : Long
        - autor : String = "tecnico"
    }

    class LineaPresupuesto <<data class>> {
        - concepto : String
        - cantidad : Int
        - precioUnitario : Double
    }

    class Notificacion <<data class>> {
        - id : String
        - userId : String
        - titulo : String
        - mensaje : String
        - leida : Boolean = false
        - createdAt : Long
        - averiaId : String
    }

    class Servicio <<data class>> {
        - id : String
        - titulo : String
        - descripcion : String
        - activo : Boolean = true
    }

    enum EstadoAveria {
        Pendiente
        Asignada
        PendienteMaterial
        Presupuestada
        EnReparacion
        Reparado
        ListaParaRecoger
        Declinada
    }

    enum PrioridadAveria {
        Alta
        Media
        Baja
    }

    enum EstadoTecnico {
        Activo
        Inactivo
        Vacaciones
    }

    Averia "1" *-- "0..*" AveriaUpdate
    Averia "1" *-- "0..*" LineaPresupuesto
    Averia --> EstadoAveria
    Averia --> PrioridadAveria
    Usuario --> EstadoTecnico
}

package "repository" #D5F5E3 {

    class OperationsTemplateRepository {
        # ref(path: String) : DatabaseReference
        # newId(node: String) : String
        # setValue(path: String, value: Any, ok: () -> Unit, error: (String) -> Unit)
        # updateChildren(path: String, updates: Map<String, Any?>, ok: () -> Unit, error: (String) -> Unit)
        # delete(path: String, ok: () -> Unit, error: (String) -> Unit)
    }

    class AuthRepository {
        - autenticacion : FirebaseAuth
        --
        + validarCorreoPassword(correo, contrasena, validacionOK, validacionError)
        + crearUsuario(email, password, nombre, apellidos, telefono, direccion, cp, localidad, dni, creadoOK, creadoError)
    }

    class AdminRepository {
        - context : Context
        - auth : FirebaseAuth
        - NODE : String = "users"
        --
        + crearUsuarioAdmin(email, nombre, apellidos, telefono, direccion, codigoPostal, localidad, dni, role, exito, error)
        + editarUsuarioParcial(userId: String, updates: Map<String, Any?>, exito, error)
        + darDeBajaUsuario(userId: String, exito, error)
    }

    class DeviceRepository {
        - auth : FirebaseAuth
        - NODE : String = "devices"
        --
        + crearEquipo(equipo: Equipo, error, exito)
        + crearEquipoAdmin(equipo: Equipo, userId: String, exito, error)
        + obtenerEquipos(error, exito)
        + eliminarEquipo(devicesId: String, error, exito)
    }

    class RepairRepository {
        - auth : FirebaseAuth
        - NODE : String = "repairs"
        --
        + abrirAveria(averia: Averia, exito, fallo)
        + crearAveriaAdmin(averia: Averia, userId: String, exito, fallo)
        + obtenerAveriasTodas(fallo, exito)
        + obtenerAveriaUser(fallo, exito)
        + obtenerAveriaId(averiaId: String, fallo, exito)
        + obtenerAveriasTecnico(fallo, exito)
        + editarAveria(averiaEditada: Averia, exito, fallo)
        + eliminarAveria(averiaId: String, exito, fallo)
    }

    class UserRepository {
        - auth : FirebaseAuth
        - NODE : String = "users"
        --
        + obtenerCualquierUsuarioPorId(id: String, exito, fallo)
        + obtenerUsuariosTodos(fallo, exito)
        + obtenerAveriasPorUsuario(userId: String, fallo, exito)
    }

    class TecnicoRepository {
        - auth : FirebaseAuth
        - NODE : String = "users"
        --
        + obtenerTecnicos(fallo, exito)
        + editarTecnico(tecnicoEditado: Usuario, fallo, exito)
        + editarTecnicoParcial(tecnicoId: String, updates: Map<String, Any?>, fallo, exito)
        + eliminarTecnico(tecnicoId: String, fallo, exito)
    }

    class ServiceRepository {
        - NODE : String = "services"
        --
        + obtenerServicios(fallo, exito)
        + crearServicio(servicio: Servicio, exito, fallo)
        + editarServicio(servicio: Servicio, exito, fallo)
        + eliminarServicio(id: String, exito, fallo)
    }

    class NotificationRepository {
        - NODE : String = "notifications"
        --
        + enviarNotificacion(notificacion: Notificacion, exito, fallo)
        + obtenerMisNotificaciones(fallo, exito)
        + escucharNotificacionesNoLeidas(userId: String, onChange: (Int) -> Unit)
        + marcarComoLeida(notifId: String, exito, fallo)
    }

    OperationsTemplateRepository <|-- AuthRepository
    OperationsTemplateRepository <|-- AdminRepository
    OperationsTemplateRepository <|-- DeviceRepository
    OperationsTemplateRepository <|-- RepairRepository
    OperationsTemplateRepository <|-- UserRepository
    OperationsTemplateRepository <|-- TecnicoRepository
    OperationsTemplateRepository <|-- ServiceRepository
    OperationsTemplateRepository <|-- NotificationRepository
}

package "ui.navigation" #FDEBD0 {

    class Rutas <<sealed class>> {
        - ruta : String
        ==
        LOGIN
        REGISTRO
        USERSCREEN
        ADD_EQUIPO
        ADMINSCREEN
        REGISTRO_TECNICO
        TECNICOSCREEN
        TESTCRUD
        REPAIRSSCREEN
        DETALLE_AVERIA_TECNICO
        DETALLE_AVERIA_FINALIZADA
        PROFILE
        CLIENTES_ADMIN
        LISTA_TECNICOS
        PRESUPUESTOS_ADMIN
        LISTA_PARA_RECOGER
        CREAR_AVERIA_ADMIN
        SERVICES_ADMIN
        NOTIFICATIONS
        DETALLE_PRESU_CLIENTE
    }

    class AppNavigation {
        --
        + navegarApp()
    }

    AppNavigation --> Rutas
}

